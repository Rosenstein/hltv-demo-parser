.home .hero img
  max-width: 100%
  margin: 2rem auto

.home .hero .description
  max-width: 36rem
  margin: 1rem auto
  font-size: 1.2rem

.home .features
  border-top: 1px solid $borderColor
  padding: 2.5rem 0

.home .feature
  text-align: center
  padding: 1.5rem

.home .feature h2
  font-size: 1.4rem
  font-weight: 600
  margin-bottom: 0.75rem
  color: $accentColor

.home .feature p
  color: lighten($textColor, 15%)

.navbar .logo
  border-radius: 4px

table
  display: table
  width: 100%

.custom-block.tip
  border-color: $accentColor

.page-edit .edit-link a
  color: $accentColor

.page-edit .last-updated .prefix
  font-weight: 600

code
  color: #e53935
  background-color: #fce4ec
  font-size: 0.85em
  padding: 0.2em 0.4em
  border-radius: 3px

pre code
  color: inherit
  background-color: transparent
  padding: 0

.content:not(.custom)
  max-width: $contentWidth

.sidebar .sidebar-sub-headers
  font-size: 0.85em

.sidebar-heading
  font-weight: 700

.navbar .links
  font-size: 0.9rem
